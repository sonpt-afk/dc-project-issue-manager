<atlassian-plugin key="${atlassian.plugin.key}" name="${project.name}" plugins-version="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
        <vendor name="${project.organization.name}" url="${project.organization.url}" />
        <param name="plugin-icon">images/pluginIcon.png</param>
        <param name="plugin-logo">images/pluginLogo.png</param>
    </plugin-info>

    <!-- add our i18n resource -->
    <resource type="i18n" name="i18n" location="dc-project-issue-viewer"/>
    
    <!-- add our web resources -->
    <web-resource key="dc-project-issue-viewer-resources" name="dc-project-issue-viewer Web Resources">
        <dependency>com.atlassian.auiplugin:ajs</dependency>
        
        <resource type="download" name="dc-project-issue-viewer.css" location="/css/dc-project-issue-viewer.css"/>
        <resource type="download" name="dc-project-issue-viewer.js" location="/js/dc-project-issue-viewer.js"/>
        <resource type="download" name="images/" location="/images"/>

        <context>dc-project-issue-viewer</context>
    </web-resource>
    
    <!-- <web-item key="project-viewer-menu-item" section="system.top.navigation.bar/project_menu" weight="1000">
        <label>Project Issue Viewer</label>
        <link>/plugins/servlet/project-viewer</link>
    </web-item> -->

<web-item key="release-page" i18n-name-key="version.release" section="jira.project.sidebar.plugins.navigation" weight="300">
    <label>Project Issue Viewer</label>
    <link>/projects/$pathEncodedProjectKey?selectedItem=com.atlassian.trainDS.dc-project-issue-viewer:release-page</link>
    <param name="iconUrl" value="https://randomuser.me/api/portraits/men/75.jpg"/>
    <param name="iconClass" value="aui-icon-large icon-sidebar-release"/>
</web-item>
 
<web-panel key="release-page-key" location="com.atlassian.trainDS.dc-project-issue-viewer:release-page">
    <!-- <resource name="view" type="soy" location=":project-subpages-soy/Jira.Projects.Release.Templates.page"/>
    <context-provider class="com.atlassian.jira.projects.page.release.ReleasePageContextProvider"/>
    <condition class="com.atlassian.jira.projects.page.release.VersionsDefinedAndVisibleCondition"/> -->

    <resource name="view" type="velocity" location="templates/app.vm"/>
		<!-- <context-provider class="jp.ricksoft.plugins.issueeditor.projectpanel.IssueEditorProjectTabPanelContextProvider"/> -->
</web-panel>

    <servlet key="project-viewer-servlet" class="com.atlassian.trainDS.servlet.AppServlet">
        <url-pattern>/project-viewer</url-pattern>
    </servlet>
    
    <servlet key="project-viewer-config-servlet" class="com.atlassian.trainDS.servlet.ConfigServlet">
      <url-pattern>/admin/project-viewer-config</url-pattern>
    </servlet>

    <web-item key="project-viewer-menu-project" section="jira.project.sidebar.plugins.navigation" weight="400">
  <label>Project Viewer Config (Project Sidebar)</label>
  <link>/plugins/servlet/admin/project-viewer-config</link>
</web-item>

    <web-resource key="project-viewer-resources">
        <dependency>com.atlassian.auiplugin:aui-page-header</dependency>
        <resource type="download" name="app-bundle.js" location="js/app-bundle.js"/>
        <context>jira.general</context> 
    </web-resource>
</atlassian-plugin>
